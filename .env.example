# ── Telegram (REQUIRED) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to receive reports and send commands
# Use @userinfobot in Telegram to find your chat/user IDs
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=

# ── Meta Ads (Phase 2) ─────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── Google Analytics 4 (Phase 3) ───────────────────────────────────────────────
GA4_PROPERTY_ID=
# Path to your GA4 service account JSON key file
GA4_SERVICE_ACCOUNT_JSON=./secrets/ga4.json

# ── Anthropic (Phase 4) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Monthly spend ceiling for AI chat (USD). Default $20.
ANTHROPIC_MONTHLY_BUDGET_USD=20.0

# ── Sentry (Phase 5 — optional) ────────────────────────────────────────────────
# Leave blank to disable error reporting. Get DSN from sentry.io (free tier).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ── Dead-man's-switch (Phase 5 — optional) ─────────────────────────────────────
# healthchecks.io ping URL. Leave blank to disable. Set period=24h, grace=2h.
HEARTBEAT_URL=

# ── Streamlit Dashboard (Phase 6 — optional) ──────────────────────────────────
# Single shared password for the Streamlit dashboard.
# Leave blank for open access (local dev only — do NOT leave blank in production).
DASHBOARD_PASSWORD=

# ── Application ────────────────────────────────────────────────────────────────
# Local dev: use a relative path. Docker/server: /data/metrics.db
DB_PATH=./data/metrics.db
LOG_LEVEL=INFO
# Your local timezone for report scheduling, e.g. Europe/London, America/New_York
REPORT_TIMEZONE=UTC
