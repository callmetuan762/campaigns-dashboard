# ── Telegram (REQUIRED) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to receive reports and send commands
# Use @userinfobot in Telegram to find your chat/user IDs
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=

# ── Meta Ads (Phase 2) ─────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── Google Analytics 4 (Phase 3) ───────────────────────────────────────────────
GA4_PROPERTY_ID=
# Path to your GA4 service account JSON key file
GA4_SERVICE_ACCOUNT_JSON=./secrets/ga4.json

# ── Shopify (funnel-v3: preorder purchases) ────────────────────────────────────
# Leave both blank to disable — Shopify ingest is a clean no-op (like Sheets/Sentry).
# Custom-app Admin API access token (Settings > Apps and sales channels > Develop apps).
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2025-01

# ── Funnel v3 config (GA4 event-level ingestion) ───────────────────────────────
# Comma-separated GA4 event names to pull event-level counts for (segmented by the
# lp_slug custom dimension). Leave blank to use the default funnel + quiz event list.
GA4_EVENT_LIST=
PRIMARY_CONVERSION_EVENT=begin_checkout
PURCHASE_EVENT=purchase
LEAD_EVENT=lead_submit

# ── Anthropic (Phase 4) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Monthly spend ceiling for AI chat (USD). Default $20.
ANTHROPIC_MONTHLY_BUDGET_USD=20.0

# ── MMM (Phase 8) ──────────────────────────────────────────────────────────────
# MMM: monetary value of one deposit in USD. Set to 0 (default) to report in
# "deposits per $1000 spend" units instead of true ROAS. (D-09)
DEPOSIT_VALUE_USD=0.0

# ── Sentry (Phase 5 — optional) ────────────────────────────────────────────────
# Leave blank to disable error reporting. Get DSN from sentry.io (free tier).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ── Dead-man's-switch (Phase 5 — optional) ─────────────────────────────────────
# healthchecks.io ping URL. Leave blank to disable. Set period=24h, grace=2h.
HEARTBEAT_URL=

# ── Streamlit Dashboard (Phase 6 — optional) ──────────────────────────────────
# Single shared password for the Streamlit dashboard.
# Leave blank for open access (local dev only — do NOT leave blank in production).
DASHBOARD_PASSWORD=

# Target Cost-per-Deposit (CPD) in USD for TIER tag classification.
# 0.0 (default) hides the TIER column. Set a positive number (e.g. 25.0) to
# enable SCALE / MAINTAIN / REDUCE / PAUSED tags on the campaign table.
CPD_TARGET=0.0

# ── Application ────────────────────────────────────────────────────────────────
# Local dev: use a relative path. Docker/server: /data/metrics.db
DB_PATH=./data/metrics.db
LOG_LEVEL=INFO
# Your local timezone for report scheduling, e.g. Europe/London, America/New_York
REPORT_TIMEZONE=UTC
